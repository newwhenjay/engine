#!/usr/bin/env bash
#
# Short alias for launching the OIE Administrator over HTTPS (8443).
#
# Usage:
#   ./client-https
#   ./client-https [serverUrl] [version] [username] [password]
#

set -euo pipefail

OIE_HOME="$( cd "$( dirname "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )"
cd "$OIE_HOME"

if [[ $# -gt 0 ]]; then
  exec "$OIE_HOME/oieadmin" "$@"
else
  exec "$OIE_HOME/oieadmin" "https://127.0.0.1:8443" "4.5.2" "admin" "admin"
fi

