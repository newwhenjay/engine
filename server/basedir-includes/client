#!/usr/bin/env bash
#
# Short alias for launching the OIE Administrator.
#
# Usage:
#   ./client
#   ./client [serverUrl] [version] [username] [password]
#
# Examples:
#   ./client
#   ./client "https://127.0.0.1:8443" "4.5.2" "admin" "admin"
#

set -euo pipefail

OIE_HOME="$( cd "$( dirname "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )"
cd "$OIE_HOME"

if [[ $# -gt 0 ]]; then
  exec "$OIE_HOME/oieadmin" "$@"
else
  exec "$OIE_HOME/oieadmin" "http://127.0.0.1:8080" "4.5.2" "admin" "admin"
fi

